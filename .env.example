# Supabase project URL — found in your Supabase dashboard under Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key — safe to expose in the browser; enforces Row Level Security
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: test account credentials used for automated testing only; not required for production
BOLT_TEST_USER_EMAIL=your-test-email@example.com
BOLT_TEST_USER_PASSWORD=your-test-password
