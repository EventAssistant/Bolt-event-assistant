# Supabase project URL — found in your Supabase dashboard under Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key — safe to expose in the browser; enforces Row Level Security
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: test account credentials used for automated testing only; not required for production
BOLT_TEST_USER_EMAIL=your-test-email@example.com
BOLT_TEST_USER_PASSWORD=your-test-password

# Demo mode — Networking Snapshot feature (/demo route)
# VITE_DEMO_ACCESS_CODE — the access code shown on the /demo code-entry screen
VITE_DEMO_ACCESS_CODE=your-demo-code-here

# EmailJS credentials for the public /demo email send (separate from authenticated app settings)
# Service ID: EmailJS Dashboard → Email Services
# Public Key: EmailJS Dashboard → Account → API Keys
# Template: create a template named "demo_snapshot_report" in your EmailJS dashboard
VITE_EMAILJS_SERVICE_ID=your-emailjs-service-id
VITE_EMAILJS_PUBLIC_KEY=your-emailjs-public-key
